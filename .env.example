# Sira session cookie encryption (64 hex chars)
SIRA_MASTER_SECRET=

# JWT signing for REST Bearer tokens and Sira refreshAuth (min 16 chars)
JWT_SECRET=

# Server (Render sets PORT automatically)
okPORT=3000
HOST=0.0.0.0

# SQLite (default: ./data/chat.db at repo root)
DATABASE_PATH=

# Deploy: see DEPLOY.md (single free Render web service = one public HTTPS URL)
